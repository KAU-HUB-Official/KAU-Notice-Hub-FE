# FastAPI backend base URL.
# The frontend proxies /api/* requests to this API.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Optional server-only override. Use this when the browser-facing API URL and
# the Next.js server-to-backend URL must differ.
NOTICE_API_BASE_URL=

# Shared secret for forwarding the real browser IP to the backend so its per-IP
# rate limit works behind this BFF proxy. Must match the backend's
# INTERNAL_PROXY_TOKEN (a random string). If empty, the real client IP is not
# forwarded and the backend rate limit becomes effectively global.
NOTICE_API_INTERNAL_TOKEN=

# Public site origin used for SEO metadata, canonical URLs, sitemap, and robots.
# Set this to the deployed origin in production (e.g. https://kau-notice-hub.vercel.app).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Public footer links.
NEXT_PUBLIC_GITHUB_URL=https://github.com/KAU-HUB-Official
NEXT_PUBLIC_CONTACT_EMAIL=qktjwl123@gmail.com
